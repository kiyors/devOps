# -----------------------------------------------------------------------------
# Huly Self-Hosted Environment Variables
# -----------------------------------------------------------------------------

# Primary Domain/URL for the frontend
# Note: Do not add a trailing slash (e.g., http://huly.local or https://huly.yourdomain.com)
FRONT_URL=http://localhost:80

# General configuration
TITLE="Huly Self Host"
DEFAULT_LANGUAGE=en
LAST_NAME_FIRST=true
DESKTOP_CHANNEL=0.7.423
HULY_VERSION=v0.7.423

# -----------------------------------------------------------------------------
# Secrets and Passwords (CHANGE THESE IN PRODUCTION)
# -----------------------------------------------------------------------------
# Generate these using: openssl rand -hex 32

# Master secret for signing tokens
SECRET=generate_a_secure_random_secret_here

# CockroachDB Configuration
CR_DATABASE=defaultdb
CR_USERNAME=selfhost
CR_USER_PASSWORD=generate_a_secure_random_secret_here

# Redpanda (Kafka) Configuration
REDPANDA_ADMIN_USER=superadmin
REDPANDA_ADMIN_PWD=generate_a_secure_random_secret_here
